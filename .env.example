# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Supabase PostgreSQL connection (decompose your connection string)
# From Supabase Dashboard > Settings > Database > Connection string (URI)
POSTGRES_HOST=aws-0-us-east-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_USER=postgres.your-project-ref
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=postgres

# Supabase client (for optional metadata operations)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key
