# =============================================================================
# LunarTech Handbook Generator - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# xAI Grok 4.1 (LLM)
# -----------------------------------------------------------------------------
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.1

# -----------------------------------------------------------------------------
# Supabase (Database + Vector Store via pgvector)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# PostgreSQL connection (used by LightRAG storage backends)
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=postgres

# -----------------------------------------------------------------------------
# LightRAG (Knowledge Graph RAG)
# -----------------------------------------------------------------------------
LIGHTRAG_WORKING_DIR=./rag_storage
LIGHTRAG_CHUNK_TOKEN_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP=100

# -----------------------------------------------------------------------------
# Embedding Model (local, used by LightRAG)
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIM=384

# -----------------------------------------------------------------------------
# Handbook Generation (AgentWrite / LongWriter)
# -----------------------------------------------------------------------------
MIN_WORDS_PER_PARAGRAPH=800
MAX_WORDS_PER_PARAGRAPH=1200
TARGET_HANDBOOK_WORDS=20000

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=7860
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# -----------------------------------------------------------------------------
# AWS Credentials (reserved for future use)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
BEDROCK_API_KEY=
